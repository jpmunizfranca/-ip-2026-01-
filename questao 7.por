programa {
  funcao inicio() {
    real f, c, mm
    inteiro p

escreva("Me fale um temeperatura em Fahrenheit e uma quantidade de chuvas em polegadas.")
leia(f) leia(p)
c = 5 * (f - 32) / 9
mm = p / 25.4
escreva("O valor em Celsius é = ") escreva(c) 
escreva("\nA quantidade de chuva em mm é = ") escreva(mm)





  }
}
