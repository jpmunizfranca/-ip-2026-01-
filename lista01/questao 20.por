programa
{
    funcao inicio()
    {
    inteiro horas, minutos, segundos, tempo

      
    escreva("Digite as horas: ")
    leia(horas)

    escreva("Digite os minutos: ")
    leia(minutos)

    escreva("Digite os segundos: ")
    leia(segundos)

    tempo = (horas * 3600) + (minutos * 60) + segundos

    escreva("O tempo em segundos é = ") escreva(tempo) escreva("\n")
    }
}
