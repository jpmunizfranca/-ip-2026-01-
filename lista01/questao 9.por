programa {
  funcao inicio() {
    real delta, a, b, c
    escreva("Me fale os valores de a, b e c.")
    leia(a, b, c)
    delta = (b * b) - (4 * a * c)
escreva("O valor de delta é = ") escreva(delta) escreva("\n")
//Não consegui achar uma expressão em Portugol que aproximasse o número a no máximo duas casas decimais.
  }
}
